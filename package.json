  },
  "keywords": [
    "typescript",
    "grid",
    "simulation",
    "2d-array",
    "testing",
    "vitest"
  ],
  "author": "Candy Cheng <candycheng.it@gmail.com>",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}